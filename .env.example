# AI Furniture Detector Configuration
# Copy this file to .env and customize for your environment

# Model Configuration
MODEL_PATH=./yolov8x-worldv2.pt
DEFAULT_CONFIDENCE=0.00
DEFAULT_IOU=0.20
MIN_BOX_AREA_RATIO=0.00001

# Server Configuration
API_HOST=127.0.0.1
API_PORT=8000
WEB_HOST=127.0.0.1
WEB_PORT=7860
WORKERS=1

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Paths
EXPORTS_DIR=./ai-furniture-detector/exports

# Debug Mode
DEBUG=false
